OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxx
OPENROUTER_BASE=https://openrouter.ai/api/v1
# OpenRouter's free router auto-selects an available free model, so a single
# free model being retired won't break the app. Override with a specific slug
# if you prefer (e.g. meta-llama/llama-3.3-70b-instruct for the paid version).
MODEL=openrouter/free
APP_REFERER=http://localhost:8000
APP_TITLE=AI Doctor App
ALLOWED_ORIGINS=*

# Pinecone (vector DB for medical knowledge retrieval)
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxx
PINECONE_INDEX_NAME=medical-knowledge

# Optional for local inference
OLLAMA_URL=http://host.docker.internal:11434
